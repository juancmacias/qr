# Configuración de Entorno - PHP QR Code
# Copia este archivo a .env y ajusta según tus necesidades

# Entorno: local o production
# Si no se especifica, se detecta automáticamente según el dominio
ENVIRONMENT=local

# Configuraciones personalizadas (opcional)
# Estas sobrescribirán las configuraciones por defecto

# DEBUG_MODE=true
# CACHE_ENABLED=true
# QR_FIND_BEST_MASK=true
# QR_PNG_MAXIMUM_SIZE=1024
